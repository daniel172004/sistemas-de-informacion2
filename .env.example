# Copia este archivo como .env y reemplaza los valores por los de tu proyecto Supabase.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key-o-service-role-key

# true = la app Streamlit intenta guardar en Supabase
# false = la app usa memoria local para pruebas rápidas
USE_SUPABASE=false
